    {
      "parameters": {
        "jsCode": "function extractEmail(s) {\n  if (!s) return null;\n  const m = s.match(/<([^>]+)>/);\n  return (m ? m[1] : s).trim().toLowerCase();\n}\n\nconst rawFrom = $json.from || null;\nconst fromEmail = extractEmail(rawFrom);\n\nconst senders = $json.all_senders || [];\nconst isMatch = senders.includes(fromEmail);\n\nreturn [\n  {\n    json: {\n      from_email: fromEmail,\n      is_known_sender: isMatch,\n      metadata: $json.metadata || {},\n      subject: $json.subject || \"\",\n      to: $json.to || \"\",\n      message_id: $json.metadata?.[\"message-id\"] || null,\n      x_wf_thread: $json.metadata?.[\"x-wf-thread\"] || null,\n      textPlain: $json.textPlain || null\n    }\n  }\n];\n"
      },
