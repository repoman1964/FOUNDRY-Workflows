    {
      "parameters": {
        "jsCode": "const replies = $items(\"Get ReplyZeros\").map(i => i.json.body).filter(Boolean);\n\nif (replies.length === 0) {\n  throw new Error(\"No canned replies found.\");\n}\n\nconst randomIndex = Math.floor(Math.random() * replies.length);\nconst selectedReply = replies[randomIndex];\n\nreturn [\n  {\n    json: {\n      canned_reply: selectedReply\n    }\n  }\n];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2256,
        -96
