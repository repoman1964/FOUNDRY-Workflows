      "id": "4bcbefbc-5272-45d0-8a9e-ef1101c8b09b",
      "name": "Get Random ReplyZero"
    },
    {
      "parameters": {
        "jsCode": "const scheduleWindow = $json.schedule_window_et || \"09:00–16:00\";\nconst [startStr, endStr] = scheduleWindow.split(\"–\").map(s => s.trim());\nconst [startHour, startMin] = startStr.split(\":\").map(Number);\nconst [endHour, endMin] = endStr.split(\":\").map(Number);\n\nconst createdAt = new Date($json.created_at);  // ISO timestamp\nconst tz = $json.tz_anchor || \"America/New_York\";\n\nconst MIN_MS = 5 * 60 * 1000;         // 5 minutes\nconst SHORT_MAX_MS = 60 * 60 * 1000;  // 60 minutes\nconst LONG_MAX_MS = 36 * 60 * 60 * 1000; // 36 hours\n\nfunction isWithinWindow(date) {\n  const options = { timeZone: tz, hour12: false };\n  const hour = Number(date.toLocaleString(\"en-US\", { hour: '2-digit', ...options }));\n  const minute = Number(date.toLocaleString(\"en-US\", { minute: '2-digit', ...options }));\n  const totalMinutes = hour * 60 + minute;\n  const startTotal = startHour * 60 + startMin;\n  const endTotal = endHour * 60 + endMin;\n  return totalMinutes >= startTotal && totalMinutes <= endTotal;\n}\n\n// Choose short (60%) or long (40%) range\nconst useShort = Math.random() < 0.6;\n\nlet validTime;\nfor (let i = 0; i < 50; i++) {\n  const offset = useShort\n    ? MIN_MS + Math.random() * (SHORT_MAX_MS - MIN_MS)\n    : SHORT_MAX_MS + Math.random() * (LONG_MAX_MS - SHORT_MAX_MS);\n\n  const candidate = new Date(createdAt.getTime() + offset);\n\n  if (isWithinWindow(candidate)) {\n    validTime = candidate;\n    break;\n  }\n}\n\nif (!validTime) {\n  throw new Error(\"Couldn't find a valid send time within constraints.\");\n}\n\nreturn [\n  {\n    json: {\n      send_at: validTime.toISOString()\n    }\n  }\n];\n"
      },
